{
	"name": "itx/csv-editor",
	"description": "TYPO3 backend CSV editor for filelist integration",
	"type": "typo3-cms-extension",
	"license": "GPL-3.0-or-later",
	"homepage": "http://www.itx.de",
	"authors": [
		{
			"name": "itx informationssysteme gmbh",
			"email": "support@itx.de",
			"role": "Developer"
		}
	],
	"support": {
		"email": "support@itx.de",
		"issues": "https://github.com/typo3-itx/jobapplications/issues",
		"docs": "https://docs.typo3.org/p/itx/jobapplications/main/en-us/"
	},
	"require": {
		"typo3/cms-core": "^11 || ^12 || ^13 || ^14",
		"typo3/cms-backend": "^11 || ^12 || ^13 || ^14",
		"typo3/cms-filelist": "^11 || ^12 || ^13 || ^14"
	},
	"autoload": {
		"psr-4": {
			"Itx\\CsvEditor\\": "Classes/"
		}
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "csv_editor"
		}
	}
